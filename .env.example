# Copiá este archivo como .env.local y completá con los valores de tu proyecto Supabase
# (Supabase → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Clave service_role (SECRETA, solo del lado del servidor) — necesaria para el
# alta automática del socio como usuario de la app (usuario/clave = DNI).
# Supabase → Project Settings → API → service_role. Cargala también en Vercel.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Para Stripe (cobro del abono a los dueños) — se agrega más adelante
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
